.vs/
*.user
*.userosscache
*.suo
*.cache

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
.nuget/
packages/

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
